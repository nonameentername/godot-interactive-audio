<CsoundSynthesizer>
<CsOptions>
-+rtmidi=NULL -M0 -n -t120
</CsOptions>
<CsInstruments>
sr = 44100
ksmps = 32
nchnls = 2
0dbfs = 1


iDrumsSF2 sfload "assets/128-016-Power.sf2"
sfpassign 0, iDrumsSF2

chnset 0, "play_drums"


opcode SendMidiNote, 0, iii
  iChan, iNote, iVel xin

  xtratim 0.25

  if timeinstk() == 1 then
    midiout 144, iChan, iNote, iVel
  endif

  kRelease release
  kChanged changed kRelease

  if kChanged == 1 && kRelease == 1 then
    midiout 128, iChan, iNote, 0
  endif
endop


instr ambience, 6
  SendMidiNote 6, p4, p5
endin

instr atmosphere, 5
  SendMidiNote 5, p4, p5
endin

instr bass1, 3
  SendMidiNote 3, p4, p5
endin

instr bass2, 9
  SendMidiNote 9, p4, p5
endin

instr dirty_base, 4
  SendMidiNote 4, p4, p5
endin

instr drums, 1
  inum  init    p4
  ivel  init    p5
  kenv  linsegr 1, 1, 1, .1, 0
  kamp  = kenv * ivel * 0.0000001 
  kfreq init 1

  kplay_drums chnget "play_drums"

  if kplay_drums == 1 then
    a1, a2 sfplay3 ivel, inum, kamp, kfreq, 0
  else
    a1 = 0
    a2 = 0
  endif

  outs a1, a2
endin

instr guitar, 2
  SendMidiNote 2, p4, p5
endin


instr space, 7
  SendMidiNote 7, p4, p5
endin


instr marker, 8
  rewindscore
endin


iTempo = 120
tempo iTempo, 120

instr update_tempo, 100
  kTempo init 120
  kTempo chnget "tempo"
  tempo kTempo, 120

  kCurrentTime times
  chnset kCurrentTime, "time"
endin

</CsInstruments>

<CsScore>
f0 z

t 0 120

